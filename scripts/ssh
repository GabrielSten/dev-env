#!/bin/bash

set -e

# Install dependencies if missing
install_deps() {
  if [ -f /etc/os-release ]; then
    . /etc/os-release
    if [[ "$ID" == "debian" || "$ID" == "ubuntu" ]]; then
      sudo apt-get update
      sudo apt-get install -y gnupg curl
    elif [[ "$ID" == "fedora" ]]; then
      sudo dnf install -y gnupg2 curl
    fi
  fi
}

for cmd in gpg curl grep mkdir chmod getent; do
  if ! command -v $cmd &>/dev/null; then
    install_deps
    break
  fi
done

# Known SSH public key (openpgp:0xBCBADC7D)
SSH_KEY="ssh-rsa  openpgp:0xBCBADC7D"

USER_HOME="${HOME:-$(getent passwd "$USER" | cut -d: -f6)}"

# Import GPG public key (local file preferred, fall back to github)
if [[ -f "$USER_HOME/.gnupg/public_key_0xBB516A57B6C1110A.asc" ]]; then
  gpg --import "$USER_HOME/.gnupg/public_key_0xBB516A57B6C1110A.asc"
else
  curl -sSL https://github.com/gabrielsten.gpg | gpg --import
fi

SSH_DIR="$USER_HOME/.ssh"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

AUTHORIZED_KEYS="$SSH_DIR/authorized_keys"
touch "$AUTHORIZED_KEYS"
grep -qxF "$SSH_KEY" "$AUTHORIZED_KEYS" || echo "$SSH_KEY" >> "$AUTHORIZED_KEYS"
chmod 600 "$AUTHORIZED_KEYS"

echo "SSH key from GPG imported and authorized for user $USER."

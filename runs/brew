#!/usr/bin/env bash

brew update
brew upgrade

brew install oven-sh/bun/bun curl fzf go gopass grep grip k9s kustomize lua luarocks ollama openssh pass ripgrep sqlite tmux wget koekeishiya/formulae/yabai yq jq neovim gpg zoxide gh ykman copilot-cli int128/kubelogin/kubelogin

brew install --cask microsoft-outlook slack rectangle google-chrome font-jetbrains-mono-nerd-font adobe-creative-cloud alacritty blender datagrip discord docker docker-desktop figma gimp notion spotify zed

# gpg: dotfiles are managed by ./dev-env — just launch the agent and import keys
source ~/.zprofile
for key in "$HOME/.gnupg/public_key_"*.asc; do
    [[ -f "$key" ]] && gpg --import "$key"
done

# ssh stuff, needs gpg
gpgconf --kill gpg-agent
gpgconf --launch gpg-agent
gpg-connect-agent updatestartuptty /bye
mkdir -p ~/.ssh
ssh-add -L > ~/.ssh/gpg_ssh_key.pub
cat ~/.ssh/gpg_ssh_key.pub >> ~/.ssh/authorized_keys
